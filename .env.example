# LLM provider: "anthropic" or "openai"
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6

# Provider API keys (only the one matching MODEL_PROVIDER is required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=email-agent
LANGSMITH_API_KEY=lsv2_...

# Gmail OAuth credentials JSON (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=~/.email-agent/credentials.json
# Token is written here automatically after first auth
GMAIL_TOKEN_PATH=~/.email-agent/token.json
